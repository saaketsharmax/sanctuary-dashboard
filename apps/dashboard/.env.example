# NextAuth
NEXTAUTH_URL=http://localhost:3005
NEXTAUTH_SECRET=your-secret-key-here-generate-with-openssl-rand-base64-32

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (optional)
GITHUB_ID=
GITHUB_SECRET=

# Supabase (optional - enables persistent database storage)
# Get these from: https://supabase.com/dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic API (optional - enables AI-powered interviews)
# Get your key from: https://console.anthropic.com/account/keys
# Without this key, the interview will run in demo mode with pre-defined questions
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Eleven Labs (optional - enables voice interview with TTS)
# Get your key from: https://elevenlabs.io/app/settings/api-keys
# Without this key, falls back to browser speech synthesis
NEXT_PUBLIC_ELEVENLABS_API_KEY=your-elevenlabs-key-here
# Optional: custom voice ID (default: Adam - pNInz6obpgDQGcFmaJgB)
NEXT_PUBLIC_ELEVENLABS_VOICE_ID=
